NEXT_PUBLIC_SITE_URL=https://atlasirwin.com
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=465
CONTACT_SMTP_SECURE=true
CONTACT_SMTP_USER=atlas.irwin.music@gmail.com
CONTACT_SMTP_PASS=your-app-password
CONTACT_EMAIL_FROM=atlas.irwin.music@gmail.com
MAILERLITE_API_KEY=your-mailerlite-api-token
MAILERLITE_GROUP_IDS=

# Atlas Release Engine (use a Supabase publishable key in the anon variable)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-legacy-anon-key
# Server-only. Used only by explicit import/seed scripts; never expose in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-or-secret-key
STUDIO_ADMIN_EMAILS=you@example.com
# Optional explicit owner for import/seed; defaults to the first allowlisted email.
STUDIO_IMPORT_ADMIN_EMAIL=you@example.com
# On localhost, Studio routes bypass magic-link auth automatically.
# Set this only if you want local writes without an auth session.
# Local demo seed remains off unless explicitly enabled.
ALLOW_STUDIO_DEMO_SEED=false

# SoundCloud Studio integration (server-only except redirect URL)
SOUNDCLOUD_CLIENT_ID=your-soundcloud-client-id
SOUNDCLOUD_CLIENT_SECRET=your-soundcloud-client-secret
# Optional; defaults to NEXT_PUBLIC_SITE_URL/studio/soundcloud/callback.
SOUNDCLOUD_REDIRECT_URI=https://atlasirwin.com/studio/soundcloud/callback
